{
  "name": "@brantrusnak/openclaw-omadeus",
  "version": "2026.4.27.1",
  "private": false,
  "description": "OpenClaw Omadeus project management channel plugin",
  "homepage": "https://github.com/brantrusnak/openclaw-omadeus-plugin#readme",
  "bugs": {
    "url": "https://github.com/brantrusnak/openclaw-omadeus-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brantrusnak/openclaw-omadeus-plugin.git"
  },
  "license": "ISC",
  "author": "Brant Rusnak",
  "type": "module",
  "main": "./index.ts",
  "scripts": {
    "test": "vitest run",
    "prepack": "node ./scripts/verify-npm-files.mjs"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "files": [
    "index.ts",
    "setup-entry.ts",
    "api.ts",
    "runtime-api.ts",
    "openclaw.plugin.json",
    "src",
    "!**/*.test.ts"
  ],
  "devDependencies": {
    "openclaw": ">=2026.4.10",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.10"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "omadeus",
      "label": "Omadeus",
      "selectionLabel": "Omadeus (WebSocket)",
      "docsPath": "/channels/omadeus",
      "docsLabel": "omadeus",
      "blurb": "Omadeus project management — tasks, chat rooms, and sprints.",
      "order": 70
    },
    "install": {
      "localPath": ".",
      "defaultChoice": "local"
    }
  }
}
